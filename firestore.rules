rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Regras para a coleção de congregações
    match /congregations/{congregationId} {
      // Permitir leitura para usuários autenticados
      allow read: if isAuthenticated();
      
      // Permitir escrita (create, update, delete) para usuários autenticados
      allow create, update, delete: if isAuthenticated();
    }
    
    // Regras para a coleção de eventos
    match /events/{eventId} {
      // Permitir leitura para usuários autenticados
      allow read: if isAuthenticated();
      
      // Permitir escrita (create, update, delete) para usuários autenticados
      allow create, update, delete: if isAuthenticated();
    }
    
    // Regras para a coleção de usuários (se houver)
    match /users/{userId} {
      // Permitir leitura e escrita para usuários autenticados
      allow read, write: if isAuthenticated();
    }
    
    // Regras para a coleção de agendamentos de reforços
    match /reforco-schedules/{scheduleId} {
      // Permitir leitura e escrita para usuários autenticados
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Regras para a coleção de dados de batismos
    match /batismo-data/{batismoId} {
      // Permitir leitura e escrita para usuários autenticados
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Regras para a coleção de dados de santa ceia
    match /santa-ceia-data/{ceiaId} {
      // Permitir leitura e escrita para usuários autenticados
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Regras para a coleção de dados de ensaios
    match /ensaio-data/{ensaioId} {
      // Permitir leitura e escrita para usuários autenticados
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Regras para a coleção de membros RJM
    match /rjmMembers/{memberId} {
      // Permitir leitura e escrita para usuários autenticados
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Regras para a coleção de recitativos RJM
    match /recitativos/{recitativoId} {
      // Permitir leitura e escrita para usuários autenticados
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Regras para a coleção de músicos
    match /musicians/{musicianId} {
      // Permitir leitura e escrita para usuários autenticados
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Regras para a coleção de setores DARPE
    match /darpeSectors/{sectorId} {
      // Permitir leitura e escrita para usuários autenticados
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Regras para a coleção de membros DARPE
    match /darpeMembers/{memberId} {
      // Permitir leitura e escrita para usuários autenticados
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Regras para a coleção de instituições DARPE
    match /darpeInstitutions/{institutionId} {
      // Permitir leitura e escrita para usuários autenticados
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Bloquear acesso a qualquer outra coleção não especificada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
